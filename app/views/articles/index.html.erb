<p style="color: green"><%= notice %></p>

<% content_for :title, "Articles" %>

<h1>Articles</h1>

<div id="articles">
  <% @articles.each do |article| %>
    <%= render article %>
    <p>
      <%= link_to "Show this article", article %>
    </p>
  <% end %>
</div>

<h1>Articles Table</h1>

<table>
  <thead>
    <tr>
      <th>Title</th>
      <th>Description</th>
      <th>Actions</th>
    </tr>
    <% @articles.each do |article| %>
    <tr>
      <td><%= article.title%></td>
      <td><%= article.description%></td>
      <td>Placeholder</td>
    </tr>
    <% end %>
  </thead>
</table>